# ─────────────────────────────────────────────────────────────
# Linux Operations Portal – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Flask runtime environment: development | production | testing
FLASK_ENV=development

# Strong random secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-strong-random-key

# PostgreSQL connection (used by Flask-SQLAlchemy and Alembic)
DATABASE_URL=postgresql://lop_user:lop_pass@localhost:5432/lop_db

# Docker Compose Postgres service vars (used by the db container)
POSTGRES_DB=lop_db
POSTGRES_USER=lop_user
POSTGRES_PASSWORD=lop_pass

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# FreeIPA / LDAP Authentication (optional)
# Set FREEIPA_ENABLED=true and fill in the remaining vars to
# activate LDAP-first login.  See docs/FREEIPA.md for details.
# ─────────────────────────────────────────────────────────────
FREEIPA_ENABLED=false
FREEIPA_URI=ldaps://ipa.corp.example.com
FREEIPA_BASE_DN=dc=corp,dc=example,dc=com
FREEIPA_BIND_DN=uid=svc-lop,cn=users,cn=accounts,dc=corp,dc=example,dc=com
FREEIPA_BIND_PASSWORD=change-me
FREEIPA_CA_CERT=/etc/ipa/ca.crt
# Set to false only in isolated dev environments (disables TLS cert check)
FREEIPA_VERIFY_CERT=true
