#!/usr/bin/env bash
# =============================================================================
# lop — Linux Operations Portal management CLI
#
# Usage: lop <command> [options]
#
# Commands:
#   install      Install or repair LOP
#   repair       Re-apply dependencies and service unit
#   update       Update to the latest version
#   uninstall    Remove LOP
#
#   start        Start all LOP services
#   stop         Stop LOP application services
#   restart      Restart LOP services
#   reload       Reload nginx config; reload systemd daemon
#   status       Show service status
#   health       System health report
#   logs         Tail application logs
#   diagnostics  Create a diagnostics bundle for troubleshooting
#   backup       Create a backup
#   restore      Restore from a backup
#   version      Show version information
#   help         Show this help
#
# Most commands require root. Use: sudo lop <command>
# =============================================================================

set -uo pipefail

# ── Locate scripts directory ─────────────────────────────────────────────────
# Works whether lop is run from the repo, /opt/lop, or as /usr/local/bin/lop
# (which is a symlink to /opt/lop/lop).
_lop_real="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")"
_lop_dir="$(dirname "$_lop_real")"

if [[ -d "$_lop_dir/scripts" ]]; then
    SCRIPTS_DIR="$_lop_dir/scripts"
elif [[ -d "$_lop_dir/../scripts" ]]; then
    SCRIPTS_DIR="$(cd "$_lop_dir/../scripts" && pwd)"
else
    printf "ERROR: Cannot locate scripts directory (looked in %s and %s).\n" \
        "$_lop_dir/scripts" "$_lop_dir/../scripts" >&2
    exit 1
fi

# ── Colour helpers ────────────────────────────────────────────────────────────
if [[ -t 1 ]] && command -v tput &>/dev/null; then
    _B="$(tput bold)"; _R="$(tput sgr0)"
    _G="$(tput bold)$(tput setaf 2)"; _Y="$(tput bold)$(tput setaf 3)"
    _C="$(tput bold)$(tput setaf 6)"; _W="$(tput bold)$(tput setaf 7)"
else
    _B=""; _R=""; _G=""; _Y=""; _C=""; _W=""
fi

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
    cat <<USAGE

${_B}lop${_R} — Linux Operations Portal management CLI

${_B}Usage:${_R}  lop <command> [options]

${_B}Lifecycle:${_R}
  ${_C}install${_R}       [--yes] [--force]            Install or repair LOP
  ${_C}repair${_R}        [--yes]                      Re-apply dependencies and service unit
  ${_C}update${_R}        [--yes] [--skip-backup] [--source <path>]  Update to latest version
  ${_C}uninstall${_R}     [--yes] [--preserve-data]    Remove LOP

${_B}Service management:${_R}
  ${_C}start${_R}                                      Start all LOP services
  ${_C}stop${_R}                                       Stop LOP application services
  ${_C}restart${_R}                                    Restart LOP services
  ${_C}reload${_R}                                     Reload nginx config; reload systemd daemon
  ${_C}status${_R}                                     Show concise service status
  ${_C}health${_R}        [--json]                     System health report
  ${_C}logs${_R}          [-n <lines>] [-f]            Tail application logs

${_B}Operations:${_R}
  ${_C}backup${_R}        [--quiet]                    Create a timestamped backup
  ${_C}restore${_R}       <file> [--yes]               Restore from a backup
  ${_C}diagnostics${_R}   [--output-dir <dir>]         Troubleshooting bundle
  ${_C}version${_R}                                    Show version information

${_B}Examples:${_R}
  sudo lop install
  sudo lop repair
  sudo lop update
  sudo lop start
  sudo lop restart
  sudo lop status
  sudo lop health
  sudo lop logs -f
  sudo lop backup
  sudo lop restore /var/backups/lop/lop_backup_2026-07-22_12-00-00.tar.gz
  sudo lop diagnostics
  lop version

USAGE
}

# ── show_version (no root required) ──────────────────────────────────────────
show_version() {
    local ver_file="/opt/lop/VERSION"
    [[ ! -f "$ver_file" ]] && ver_file="$_lop_dir/VERSION"

    local app_version="unknown"
    local git_commit="unknown"
    local db_schema="unknown"
    local python_version="unknown"
    local install_type="unknown"
    local deploy_path="/opt/lop"
    local source_path="unknown"
    local install_info="/var/lib/lop/install.info"

    # Application version from VERSION file
    if [[ -f "$ver_file" ]]; then
        app_version=$(grep '^APP_VERSION=' "$ver_file" 2>/dev/null | cut -d= -f2- | tr -d '[:space:]') || true
        [[ -z "$app_version" ]] && app_version="unknown"
    fi

    # Git commit — try deployed dir first, then source checkout
    git_commit=$(git -C /opt/lop rev-parse HEAD 2>/dev/null | head -c 7 || true)
    if [[ -z "$git_commit" ]] && [[ -f "$install_info" ]]; then
        local _src_dir
        _src_dir=$(grep '^install_source_dir=' "$install_info" 2>/dev/null \
                   | cut -d= -f2- | tr -d '[:space:]') || true
        if [[ -n "$_src_dir" ]] && [[ -d "$_src_dir" ]]; then
            git_commit=$(git -C "$_src_dir" rev-parse HEAD 2>/dev/null | head -c 7 || true)
        fi
    fi
    [[ -z "$git_commit" ]] && git_commit="unknown"

    # Database schema revision (non-fatal)
    if [[ -f /etc/lop/lop.env ]] && command -v psql &>/dev/null; then
        local _db_url
        _db_url=$(grep '^DATABASE_URL=' /etc/lop/lop.env 2>/dev/null | cut -d= -f2-)
        if [[ -n "$_db_url" ]]; then
            db_schema=$(psql -tAq "$_db_url" \
                -c "SELECT version_num FROM alembic_version ORDER BY version_num DESC LIMIT 1;" \
                2>/dev/null | tr -d '[:space:]' || true)
        fi
    fi
    if [[ -z "$db_schema" ]] && [[ -x "/opt/lop/venv/bin/flask" ]]; then
        db_schema=$(
            cd /opt/lop 2>/dev/null || true
            [[ -f /etc/lop/lop.env ]] && { set -a; source /etc/lop/lop.env 2>/dev/null; set +a; } || true
            FLASK_APP=run.py FLASK_ENV=production /opt/lop/venv/bin/flask db current \
                2>/dev/null | grep -oP '[0-9a-f]{12}' | head -1 || true
        ) 2>/dev/null || true
    fi
    [[ -z "$db_schema" ]] && db_schema="unknown"

    # Python version from venv
    if [[ -x "/opt/lop/venv/bin/python" ]]; then
        python_version=$(/opt/lop/venv/bin/python --version 2>&1 | awk '{print $2}')
    elif command -v python3 &>/dev/null; then
        python_version=$(python3 --version 2>&1 | awk '{print $2}')
    fi
    [[ -z "$python_version" ]] && python_version="unknown"

    # Install metadata
    if [[ -f "$install_info" ]]; then
        install_type=$(grep '^install_source=' "$install_info" 2>/dev/null \
                       | cut -d= -f2- | tr -d '[:space:]') || true
        local _src
        _src=$(grep '^install_source_dir=' "$install_info" 2>/dev/null \
               | cut -d= -f2- | tr -d '[:space:]') || true
        [[ -n "$_src" ]] && source_path="$_src"
    fi
    [[ -z "$install_type" ]] && install_type="unknown"

    printf "\n${_B}LOP Version${_R}\n"
    printf "${_W}%s${_R}\n" "────────────────────────────────────"
    printf "  %-14s %s%s%s\n" "Application :" "$_C" "$app_version"   "$_R"
    printf "  %-14s %s%s%s\n" "Git Commit  :" "$_C" "$git_commit"    "$_R"
    printf "  %-14s %s%s%s\n" "Database    :" "$_C" "$db_schema"     "$_R"
    printf "  %-14s %s%s%s\n" "Python      :" "$_C" "$python_version" "$_R"
    printf "  %-14s %s%s%s\n" "Install     :" "$_C" "$install_type"  "$_R"
    printf "  %-14s %s%s%s\n" "Deploy Path :" "$_C" "$deploy_path"   "$_R"
    printf "  %-14s %s%s%s\n" "Source Path :" "$_C" "$source_path"   "$_R"
    printf "\n"
}

# =============================================================================
# ── MAIN DISPATCH ─────────────────────────────────────────────────────────────
# =============================================================================
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in

    # ── Lifecycle ─────────────────────────────────────────────────────────────
    install)
        exec "$SCRIPTS_DIR/install.sh" "$@"
        ;;
    repair)
        exec "$SCRIPTS_DIR/install.sh" --repair "$@"
        ;;
    update|upgrade)
        # ── Resolve the source checkout, then exec update.sh from it ──────────
        #
        # update.sh derives REPO_DIR from its own path via BASH_SOURCE[0].
        # /opt/lop is the deployed copy (no .git); update.sh must run from the
        # original Git source checkout.  This block handles three cases:
        #
        #   1. --source <path>  — explicit path supplied by the operator
        #   2. install.info has a recorded install_source_dir — use it
        #   3. install_source_dir missing/invalid — auto-discover common locations
        #
        # After discovery the path is saved back to install.info so future
        # invocations do not need to search again.

        _lop_install_info="/var/lib/lop/install.info"

        # ── Parse --source flag out of "$@" ───────────────────────────────────
        # Everything else is collected in _lop_pass and forwarded to update.sh.
        _lop_explicit_src=""
        _lop_pass=()
        _lop_skip_next=0
        for _lop_a in "$@"; do
            if [[ $_lop_skip_next -eq 1 ]]; then
                _lop_explicit_src="$_lop_a"
                _lop_skip_next=0
            elif [[ "$_lop_a" == "--source" ]]; then
                _lop_skip_next=1
            elif [[ "$_lop_a" == --source=* ]]; then
                _lop_explicit_src="${_lop_a#--source=}"
            else
                _lop_pass+=("$_lop_a")
            fi
        done

        # ── Helpers ───────────────────────────────────────────────────────────

        # Read one key from install.info safely (|| true guards against pipefail).
        _lop_read_key() {
            grep "^${1}=" "$_lop_install_info" 2>/dev/null \
                | cut -d= -f2- | tr -d '[:space:]' || true
        }

        # A valid LOP source checkout must have both .git/ and scripts/update.sh.
        _lop_valid_checkout() {
            [[ -d "${1}/.git" ]] && [[ -f "${1}/scripts/update.sh" ]]
        }

        # Upsert install_source_dir in install.info so the next run is instant.
        _lop_save_src_dir() {
            [[ -f "$_lop_install_info" ]] || return 0
            if grep -q "^install_source_dir=" "$_lop_install_info" 2>/dev/null; then
                sed -i "s|^install_source_dir=.*|install_source_dir=${1}|" \
                    "$_lop_install_info"
            else
                printf "install_source_dir=%s\n" "${1}" >> "$_lop_install_info"
            fi
        }

        # Search well-known locations (and CWD) for a valid source checkout.
        # Prints one real path per line; deduplicates via realpath.
        _lop_discover() {
            local _seen=() _real _dup _d
            for _d in \
                /opt/Linux-Ops-Portal \
                /usr/local/src/Linux-Ops-Portal \
                /srv/Linux-Ops-Portal \
                "$PWD"
            do
                _lop_valid_checkout "$_d" || continue
                _real="$(realpath "$_d" 2>/dev/null || echo "$_d")"
                _dup=0
                for _s in "${_seen[@]+"${_seen[@]}"}"; do
                    [[ "$_real" == "$_s" ]] && { _dup=1; break; }
                done
                [[ $_dup -eq 0 ]] && { _seen+=("$_real"); printf '%s\n' "$_real"; }
            done
        }

        # ── Resolve the source checkout ───────────────────────────────────────
        _lop_src_dir=""

        if [[ -n "$_lop_explicit_src" ]]; then
            # ── 1. Operator supplied --source <path> ──────────────────────────
            if ! _lop_valid_checkout "$_lop_explicit_src"; then
                printf "\n[ERROR] Not a valid LOP source checkout:\n\n    %s\n\n" \
                    "$_lop_explicit_src" >&2
                printf "A valid checkout must contain .git/ and scripts/update.sh\n\n" >&2
                exit 1
            fi
            _lop_src_dir="$(realpath "$_lop_explicit_src" 2>/dev/null \
                            || echo "$_lop_explicit_src")"
            printf "[INFO] Using specified source checkout:\n       %s\n" "$_lop_src_dir"
            _lop_save_src_dir "$_lop_src_dir"
            printf "[INFO] Installation metadata updated.\n"

        elif [[ -f "$_lop_install_info" ]]; then
            # ── 2. Read install.info ───────────────────────────────────────────
            _lop_src_type=$(_lop_read_key "install_source")

            if [[ "$_lop_src_type" == "archive" ]]; then
                printf "\nArchive installations cannot be updated via 'lop update'.\n\n" >&2
                printf "Download the latest release archive and run:\n\n" >&2
                printf "    sudo ./install.sh\n\n" >&2
                exit 1
            fi

            _lop_recorded=$(_lop_read_key "install_source_dir")

            if [[ -n "$_lop_recorded" ]] && [[ "$_lop_recorded" != "unknown" ]] \
               && _lop_valid_checkout "$_lop_recorded"; then
                # Recorded path is present and valid — use it directly.
                _lop_src_dir="$_lop_recorded"

            else
                # Path is missing, "unknown", or stale — auto-discover.
                # This is the normal path for installations created before
                # install_source_dir tracking was introduced.
                if [[ -n "$_lop_recorded" ]] && [[ "$_lop_recorded" != "unknown" ]]; then
                    printf "[WARN] Recorded source checkout is no longer valid:\n" >&2
                    printf "       %s\n" "$_lop_recorded" >&2
                fi
                printf "       Searching common locations for the source checkout...\n"

                mapfile -t _lop_found < <(_lop_discover)

                if [[ ${#_lop_found[@]} -eq 0 ]]; then
                    printf "\n[ERROR] No valid Git source checkout could be located.\n\n" >&2
                    printf "Specify one with:\n\n" >&2
                    printf "    sudo lop update --source /path/to/Linux-Ops-Portal\n\n" >&2
                    printf "Or reinstall if the original source checkout has been removed:\n\n" >&2
                    printf "    sudo lop install\n\n" >&2
                    exit 1

                elif [[ ${#_lop_found[@]} -eq 1 ]]; then
                    _lop_src_dir="${_lop_found[0]}"
                    printf "[INFO] Source checkout discovered:\n       %s\n" "$_lop_src_dir"
                    _lop_save_src_dir "$_lop_src_dir"
                    printf "[INFO] Installation metadata updated.\n"

                else
                    printf "\n[INFO] Multiple valid source checkouts found:\n\n" >&2
                    _lop_n=1
                    for _lop_d in "${_lop_found[@]}"; do
                        printf "    %d.  %s\n" "$_lop_n" "$_lop_d" >&2
                        _lop_n=$((_lop_n + 1))
                    done
                    printf "\nSpecify which one to use:\n\n" >&2
                    printf "    sudo lop update --source /path/to/Linux-Ops-Portal\n\n" >&2
                    exit 1
                fi
            fi

        else
            # ── 3. No install.info — developer / direct-run path ──────────────
            # Try auto-discovery before falling back to SCRIPTS_DIR.  This lets
            # a developer run 'lop update' from any directory as long as exactly
            # one checkout is present in the well-known locations.
            mapfile -t _lop_found < <(_lop_discover)
            if [[ ${#_lop_found[@]} -eq 1 ]]; then
                _lop_src_dir="${_lop_found[0]}"
            else
                exec "$SCRIPTS_DIR/update.sh" \
                    "${_lop_pass[@]+"${_lop_pass[@]}"}"
            fi
        fi

        # ── Execute update.sh from the resolved source checkout ───────────────
        cd "$_lop_src_dir"
        exec ./scripts/update.sh "${_lop_pass[@]+"${_lop_pass[@]}"}"
        ;;
    uninstall|remove)
        exec "$SCRIPTS_DIR/uninstall.sh" "$@"
        ;;

    # ── Service management (delegated entirely to service.sh) ─────────────────
    start|stop|restart|reload|status)
        exec "$SCRIPTS_DIR/service.sh" "$COMMAND" "$@"
        ;;

    # ── Health (delegated to the full health.sh report) ───────────────────────
    health|check)
        exec "$SCRIPTS_DIR/health.sh" "$@"
        ;;

    # ── Logs (delegated to service.sh which handles -n / -f) ─────────────────
    logs)
        exec "$SCRIPTS_DIR/service.sh" logs "$@"
        ;;

    # ── Operations ────────────────────────────────────────────────────────────
    backup)
        exec "$SCRIPTS_DIR/backup.sh" "$@"
        ;;
    restore)
        exec "$SCRIPTS_DIR/restore.sh" "$@"
        ;;
    diagnostics|diag)
        exec "$SCRIPTS_DIR/diagnostics.sh" "$@"
        ;;

    # ── Version (no root required) ────────────────────────────────────────────
    version|-v|--version)
        show_version
        ;;

    # ── Help ─────────────────────────────────────────────────────────────────
    help|-h|--help|"")
        usage
        ;;

    *)
        printf "Unknown command: %s\n\n" "$COMMAND" >&2
        usage >&2
        exit 1
        ;;
esac
