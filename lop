#!/usr/bin/env bash
# =============================================================================
# lop — Linux Operations Portal management CLI
#
# Usage: lop <command> [options]
#
# Commands:
#   install      Install or repair LOP
#   update       Update to the latest version
#   backup       Create a backup
#   restore      Restore from a backup
#   health       Show system health report
#   diagnostics  Create a diagnostics bundle for troubleshooting
#   version      Show version information
#   restart      Restart LOP services
#   status       Show service status
#   logs         Tail application logs
#   uninstall    Remove LOP
#   help         Show this help
#
# Most commands require root. Use: sudo lop <command>
# =============================================================================

set -uo pipefail

# Resolve the scripts directory relative to this file.
# Works whether lop is run from the repo, /opt/lop, or as /usr/local/bin/lop.
_lop_real="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}")"
_lop_dir="$(dirname "$_lop_real")"

# Scripts can live alongside lop (repo/install dir) or in scripts/
if [[ -d "$_lop_dir/scripts" ]]; then
    SCRIPTS_DIR="$_lop_dir/scripts"
elif [[ -d "$_lop_dir/../scripts" ]]; then
    SCRIPTS_DIR="$(cd "$_lop_dir/../scripts" && pwd)"
else
    printf "ERROR: Cannot locate scripts directory.\n" >&2
    exit 1
fi

LOP_BACKEND_SERVICE="lop-backend"

# ── Colour helpers ────────────────────────────────────────────────────────────
if [[ -t 1 ]] && command -v tput &>/dev/null; then
    _B="$(tput bold)"; _R="$(tput sgr0)"
    _G="$(tput bold)$(tput setaf 2)"; _Y="$(tput bold)$(tput setaf 3)"
    _C="$(tput bold)$(tput setaf 6)"
else
    _B=""; _R=""; _G=""; _Y=""; _C=""
fi

# ── Usage ─────────────────────────────────────────────────────────────────────
usage() {
    cat <<USAGE

${_B}lop${_R} — Linux Operations Portal management CLI

${_B}Usage:${_R}  lop <command> [options]

${_B}Lifecycle:${_R}
  ${_C}install${_R}       [--yes] [--force]            Install or repair LOP
  ${_C}repair${_R}        [--yes]                      Re-apply dependencies and service unit
  ${_C}update${_R}        [--yes] [--skip-backup]      Update to latest version
  ${_C}uninstall${_R}     [--yes] [--preserve-data]    Remove LOP

${_B}Operations:${_R}
  ${_C}backup${_R}        [--quiet]                    Create a timestamped backup
  ${_C}restore${_R}       <file> [--yes]               Restore from a backup
  ${_C}health${_R}        [--json]                     System health report
  ${_C}diagnostics${_R}   [--output-dir <dir>]         Troubleshooting bundle
  ${_C}version${_R}                                    Show version information
  ${_C}restart${_R}                                    Restart LOP services
  ${_C}status${_R}                                     Show service status
  ${_C}logs${_R}          [-n <lines>] [-f]            Tail application logs

${_B}Examples:${_R}
  sudo lop install
  sudo lop repair
  sudo lop update
  sudo lop backup
  sudo lop restore /var/backups/lop/lop_backup_2026-07-22_12-00-00.tar.gz
  sudo lop health
  sudo lop diagnostics
  lop version
  sudo lop logs -f

USAGE
}

# ── show_version (no root required) ──────────────────────────────────────────
show_version() {
    local ver_file="/opt/lop/VERSION"
    [[ ! -f "$ver_file" ]] && ver_file="$_lop_dir/VERSION"

    if [[ -f "$ver_file" ]]; then
        printf "\n${_B}Linux Operations Portal${_R}\n\n"
        while IFS='=' read -r key val; do
            [[ -z "$key" ]] || [[ "$key" =~ ^# ]] || [[ "$key" =~ ^[[:space:]]*$ ]] && continue
            printf "  %-24s %s%s%s\n" "${key}:" "$_C" "$val" "$_R"
        done < "$ver_file"

        # DB schema (live, non-fatal)
        local schema=""
        if [[ -x "/opt/lop/venv/bin/flask" ]]; then
            schema=$(
                cd /opt/lop 2>/dev/null || true
                [[ -f /etc/lop/lop.env ]] && { set -a; source /etc/lop/lop.env 2>/dev/null; set +a; } || true
                FLASK_APP=run.py FLASK_ENV=production /opt/lop/venv/bin/flask db current \
                    2>/dev/null | grep -oP '[0-9a-f]{12}' | head -1
            ) 2>/dev/null || true
            [[ -n "$schema" ]] && printf "  %-24s %s%s%s\n" "DB_SCHEMA:" "$_C" "$schema" "$_R"
        fi

        # Git hash
        local git_hash=""
        git_hash=$(git -C /opt/lop rev-parse HEAD 2>/dev/null | head -c 8 || true)
        [[ -n "$git_hash" ]] && printf "  %-24s %s%s%s\n" "GIT_COMMIT:" "$_C" "$git_hash" "$_R"
        printf "\n"
    else
        printf "LOP: version information not available\n"
    fi
}

# ── logs helper (no root required) ───────────────────────────────────────────
show_logs() {
    local lines=50 follow=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n) lines="$2"; shift 2 ;;
            -n*) lines="${1#-n}"; shift ;;
            -f|--follow) follow=true; shift ;;
            *) shift ;;
        esac
    done

    if [[ "$follow" == "true" ]]; then
        exec journalctl -u "$LOP_BACKEND_SERVICE" -f 2>/dev/null \
            || exec tail -f /var/log/lop/app/error.log 2>/dev/null \
            || { printf "No log source available.\n" >&2; exit 1; }
    else
        if command -v journalctl &>/dev/null; then
            journalctl -u "$LOP_BACKEND_SERVICE" --no-pager -n "$lines" 2>/dev/null || true
        elif [[ -f /var/log/lop/app/error.log ]]; then
            tail -n "$lines" /var/log/lop/app/error.log
        else
            printf "No log source available. Try: sudo journalctl -u lop-backend\n" >&2
        fi
    fi
}

# =============================================================================
# ── MAIN DISPATCH ─────────────────────────────────────────────────────────────
# =============================================================================
COMMAND="${1:-help}"
shift 2>/dev/null || true

case "$COMMAND" in
    install)
        exec "$SCRIPTS_DIR/install.sh" "$@"
        ;;
    repair)
        # Force repair mode regardless of health check outcome.
        # Passes --repair to install.sh which sets INSTALL_MODE=repair unconditionally.
        exec "$SCRIPTS_DIR/install.sh" --repair "$@"
        ;;
    update|upgrade)
        exec "$SCRIPTS_DIR/update.sh" "$@"
        ;;
    backup)
        exec "$SCRIPTS_DIR/backup.sh" "$@"
        ;;
    restore)
        exec "$SCRIPTS_DIR/restore.sh" "$@"
        ;;
    health|check)
        exec "$SCRIPTS_DIR/health.sh" "$@"
        ;;
    diagnostics|diag)
        exec "$SCRIPTS_DIR/diagnostics.sh" "$@"
        ;;
    uninstall|remove)
        exec "$SCRIPTS_DIR/uninstall.sh" "$@"
        ;;
    version|-v|--version)
        show_version
        ;;
    restart)
        if [[ "$EUID" -ne 0 ]]; then
            printf "restart requires root. Try: sudo lop restart\n" >&2
            exit 1
        fi
        printf "Restarting lop-backend...\n"
        systemctl restart "$LOP_BACKEND_SERVICE" \
            && printf "${_G}Restarted successfully.${_R}\n" \
            || { printf "${_Y}Failed. Check: sudo journalctl -u lop-backend -n 50${_R}\n"; exit 1; }
        ;;
    status)
        if command -v systemctl &>/dev/null; then
            systemctl status "$LOP_BACKEND_SERVICE" --no-pager 2>&1 || true
        else
            printf "systemctl not available.\n" >&2
        fi
        ;;
    logs)
        show_logs "$@"
        ;;
    help|-h|--help|"")
        usage
        ;;
    *)
        printf "Unknown command: %s\n\n" "$COMMAND" >&2
        usage >&2
        exit 1
        ;;
esac
