# ─────────────────────────────────────────────────────────────
# Linux Operations Portal – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Flask runtime environment: development | production | testing
FLASK_ENV=development

# Strong random secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-a-strong-random-key

# PostgreSQL connection (used by Flask-SQLAlchemy and Alembic)
DATABASE_URL=postgresql://lop_user:lop_pass@localhost:5432/lop_db

# Docker Compose Postgres service vars (used by the db container)
POSTGRES_DB=lop_db
POSTGRES_USER=lop_user
POSTGRES_PASSWORD=lop_pass

# Logging level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
